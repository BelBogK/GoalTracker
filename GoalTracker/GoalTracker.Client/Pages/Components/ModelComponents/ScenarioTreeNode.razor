@using GoalTracker.Shared.SuperClass
@using GoalTracker.Shared
@using GoalTracker.Shared.Enums
@using MudBlazor
@inject NavigationManager Navigation
<MudTreeViewItem Value="@Scenario.Name" Expanded="true">
    <Content>
        <div style="display: flex; align-items: center; gap: 8px; width: 100%;">
            @if (Scenario.IsOprimisticScenarios)
            {
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                         Color="Color.Success" Size="Size.Small" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.TrendingDown"
                         Color="Color.Error" Size="Size.Small" />
            }
            <MudLink OnClick="() => NavigateToScen(Scenario.Id)"
                     Underline="Underline.Hover" Style="cursor: pointer;">
                <MudText Typo="Typo.body2">@Scenario.Name</MudText>
            </MudLink>
            @if (Scenario.IsActive)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                         Color="Color.Success" Size="Size.Small" />
            }
            @if (GetAggregateStatus() is { } s)
            {
                <MudIcon Icon="@GetStatusIcon(s)" Color="@GetStatusColor(s)" Size="Size.Small" />
            }
        </div>
    </Content>
    <ChildContent>
        @foreach (var project in Scenario.Projects)
        {
            <ProjectTreeNode Project="@project"
                             ShowAdd="ShowAdd" ShowRemove="ShowRemove"
                             OnAdd="OnAdd" OnRemove="OnRemove"
                             OnStatusChanged="OnStatusChanged" />
        }
        @foreach (var child in Scenario.Children)
        {
            <ScenarioTreeNode Scenario="@child"
                              ShowAdd="ShowAdd" ShowRemove="ShowRemove"
                              OnAdd="OnAdd" OnRemove="OnRemove"
                              OnStatusChanged="OnStatusChanged" />
        }
    </ChildContent>
</MudTreeViewItem>
@code {
    [Parameter] public TaskHierarchyScenarioDTO Scenario { get; set; } = new();
    [Parameter] public bool ShowAdd { get; set; }
    [Parameter] public bool ShowRemove { get; set; }
    [Parameter] public EventCallback<TaskItemDTO> OnStatusChanged { get; set; }
    [Parameter] public EventCallback<TaskItemDTO> OnAdd { get; set; }
    [Parameter] public EventCallback<TaskItemDTO> OnRemove { get; set; }

    private CurrentStatus? GetAggregateStatus()
    {
        var allTasks = Scenario.Projects.SelectMany(p => p.Tasks)
            .Concat(Scenario.Children.SelectMany(GetChildTasks))
            .ToList();
        if (!allTasks.Any()) return null;
        if (allTasks.All(t => t.CurrentStatus == CurrentStatus.Completed)) return CurrentStatus.Completed;
        if (allTasks.All(t => t.CurrentStatus == CurrentStatus.Cancelled)) return CurrentStatus.Cancelled;
        if (allTasks.Any(t => t.CurrentStatus == CurrentStatus.InProgress)) return CurrentStatus.InProgress;
        return null;
    }

    private IEnumerable<TaskItemDTO> GetChildTasks(TaskHierarchyScenarioDTO s)
        => s.Projects.SelectMany(p => p.Tasks)
            .Concat(s.Children.SelectMany(GetChildTasks));

    private Color GetStatusColor(CurrentStatus s) => s switch
    {
        CurrentStatus.InProgress => Color.Success,
        CurrentStatus.Completed => Color.Success,
        CurrentStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusIcon(CurrentStatus s) => s switch
    {
        CurrentStatus.InProgress => Icons.Material.Filled.PlayArrow,
        CurrentStatus.Completed => Icons.Material.Filled.CheckCircle,
        CurrentStatus.Cancelled => Icons.Material.Filled.Cancel,
        _ => ""
    };

    private void NavigateToScen(int scenId)
    {
        Navigation.NavigateTo($"/Scenario/{scenId}");
    }
}