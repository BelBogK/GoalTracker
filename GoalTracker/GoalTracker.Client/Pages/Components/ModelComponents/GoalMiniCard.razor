@using GoalTracker.Shared
@using GoalTracker.Shared.Enums
@using MudBlazor
@inject NavigationManager Navigation

<MudCard Style="cursor: pointer;" @onclick="() => OpenGoal(Goal.Id)">
    <MudCardContent Style="padding: 12px 16px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div style="flex: 1;">
                <MudText Typo="Typo.subtitle2">@Goal.Name</MudText>
                @if (!string.IsNullOrEmpty(Goal.Description))
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary"
                        Style="margin-top: 2px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                        @Goal.Description
                    </MudText>
                }
            </div>
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(Goal.CurrentStatus)" 
                Style="margin-left: 8px;">
                @Goal.CurrentStatus
            </MudChip>
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public GoalDTO Goal { get; set; } = new();

    private Color GetStatusColor(CurrentStatus s) => s switch
    {
        CurrentStatus.InProgress => Color.Success,
        CurrentStatus.Achieved => Color.Success,
        CurrentStatus.Cancelled => Color.Error,
        CurrentStatus.Analyzing => Color.Warning,
        _ => Color.Default
    };

    private void OpenGoal(int goalId)
    {
        Navigation.NavigateTo($"/Scenario/{goalId}");
    }
}