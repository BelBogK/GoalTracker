@using GoalTracker.Shared
@using GoalTracker.Shared.SuperClass
@using MudBlazor

@foreach (var lifeArea in Hierarchy)
{
    <MudCard Class="mb-4">
        <MudCardContent>

            @* LifeArea header *@
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Landscape" Color="Color.Primary" />
                <MudText Typo="Typo.h6">@lifeArea.Name</MudText>
            </div>

            @foreach (var goal in lifeArea.Goals)
            {
                <div style="margin-left: 16px; margin-bottom: 16px;">
                    
                    @* Goal *@
                    <GoalMiniCard Goal="@ToGoalDTO(goal)" />

                    @* Scenarios *@
                    @if (goal.Scenarios?.Any() == true)
                    {
                        <div style="margin-left: 16px; margin-top: 8px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                Style="letter-spacing: 1px; font-weight: 500; display: block; margin-bottom: 6px;">
                                SCENARIOS
                            </MudText>
                            @foreach (var scenario in goal.Scenarios)
                            {
                                <ScenarioHierarchyNode Scenario="@scenario"
                                    OnStatusChanged="OnStatusChanged" />
                            }
                        </div>
                    }

                    @* Direct projects *@
                    @if (goal.Projects?.Any() == true)
                    {
                        <div style="margin-left: 16px; margin-top: 8px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                Style="letter-spacing: 1px; font-weight: 500; display: block; margin-bottom: 6px;">
                                PROJECTS
                            </MudText>
                            @foreach (var project in goal.Projects)
                            {
                                <ProjectHierarchyNode Project="@project"
                                    OnStatusChanged="OnStatusChanged" />
                            }
                        </div>
                    }
                </div>
            }
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public List<TaskHierarchyLifeAreaDTO> Hierarchy { get; set; } = [];
    [Parameter] public EventCallback<TaskItemDTO> OnStatusChanged { get; set; }

    private GoalDTO ToGoalDTO(TaskHierarchyGoalDTO g) => new()
    {
        Id = g.Id,
        Name = g.Name,
        Description = g.Description ?? "",
        CurrentStatus = g.CurrentStatus,
        GoalType = g.GoalType,
        Priority = g.Priority
    };
}