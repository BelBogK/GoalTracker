@using MudBlazor
<MudPaper Class="doc-section-component-container mx-8">
    <MudChart ChartType="ChartType.Radar" ChartSeries="@_series" ChartLabels="@_chartLabels" ChartOptions="@_options" Width="100%" Height="500px" MatchBoundsToSize CanHideSeries />
</MudPaper> 

@code {
    [Parameter]
    public Dictionary<string,int> Potentioal{ get; set; }
    [Parameter]
    public Dictionary<string, int> Current { get; set; }

    private string[] _chartLabels = { "Strength", "Agility", "Intelligence", "Charisma", "Stamina", "Luck" };
    private List<ChartSeries<int>> _series = new List<ChartSeries<int>>();

    private RadarChartOptions _options = new RadarChartOptions
    {
        ShowGridLines = true,
        GridLevels = 3,
        GridLineColor = "rgba(128,128,128,0.3)",
        ShowAxisLabels = true,
        AxisLineColor = "navy",
        AxisLineWidth = 1.5,
        FillOpacity = 0.3,
        StrokeWidth = 2.5,
        ShowDataMarkers = true,
        DataPointRadius = 5,
        AngleOffset = 30,
        TooltipTitleFormat = "{{SERIES_NAME}}: {{X_VALUE}}",
    };

    protected override Task OnInitializedAsync()
    {
        if (Current == null)
            return base.OnInitializedAsync(); ;
        _chartLabels = Current.Keys.Select(x => x).ToArray();
        // var currentList = new List<int>();
        // var potential = new List<int>();
        // var random = new Random();

        // for (int i = 0; i < Current.Count(); i++)
        // {
        //     currentList.Add(random.Next(1, 15));
        //     potential.Add(random.Next(1, 15));
        // }
        // _series = new List<ChartSeries<int>>()
        // {
        //     new() {Name="Current", Data=currentList.ToArray()},
        //     new(){ Name="Potential", Data=potential.ToArray()}
        // };
        _series = new List<ChartSeries<int>>()
        {
            new() {Name="Current", Data=Current.Select(x=>x.Value).ToArray()},
            new(){ Name="Potential", Data=Potentioal.Select(x=>x.Value).ToArray()}
        };

        return base.OnInitializedAsync();
    }

    protected override Task OnParametersSetAsync()
    {
        if (Current == null)
            return base.OnParametersSetAsync(); ;
        _chartLabels = Current.Keys.Select(x => x).ToArray();
        _series = new List<ChartSeries<int>>()
        {
            new() {Name="Current", Data=Current.Select(x=>x.Value).ToArray()},
            new(){ Name="Potential", Data=Potentioal.Select(x=>x.Value).ToArray()}
        };

        return base.OnParametersSetAsync();
    }
}
