@using GoalTracker.Client.Feautures.Tasks
@using GoalTracker.Shared
@using GoalTracker.Shared.Enums
@using GoalTracker.Shared.SuperClass
@using MudBlazor
@inject NavigationManager Nav
@inject TaskItemApiClient TaskApi

<MudPaper Class="pa-4" Elevation="0">

    <!-- ───────────────── TOOLBAR ───────────────── -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4" Wrap="Wrap.Wrap" Spacing="2">

        <MudText Typo="Typo.h5" Class="mud-text-secondary">
            <MudIcon Icon="@Icons.Material.Filled.TaskAlt" Class="mr-2 mb-n1" />
            Tasks
        </MudText>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">

            <MudTextField Value="@SearchText"
                          ValueChanged="@((string v) => SearchText = v)"
                          Placeholder="Quick search…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="200"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="min-width:220px" />

            <MudSelect T="CurrentStatus?"
                       Value="@FilterStatus"
                       ValueChanged="@((CurrentStatus? v) => FilterStatus = v)"
                       Placeholder="All statuses"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width:180px">
                @foreach (CurrentStatus s in Enum.GetValues<CurrentStatus>())
                {
                    <MudSelectItem T="CurrentStatus?" Value="s">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@GetStatusIcon(s)" Color="@GetStatusColor(s)" Size="Size.Small" />
                            <MudText>@s.ToString()</MudText>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string"
                       Value="@FilterLifeAreaName"
                       ValueChanged="@((string v) => FilterLifeAreaName = v)"
                       Placeholder="All life areas"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width:180px">
                @foreach (var la in LifeAreas.Select(x => x.Name).Distinct())
                {
                    <MudSelectItem T="string" Value="la">@la</MudSelectItem>
                }
            </MudSelect>

        </MudStack>
    </MudStack>

    <!-- ───────────────── TABLE ───────────────── -->
    <MudTable T="FlatTaskRow"
              Items="@_filteredRows"
              Hover="true"
              Dense="true"
              Breakpoint="Breakpoint.Sm"
              RowStyleFunc="@RowStyle">

        <HeaderContent>
            <MudTh>Tasks</MudTh>
            <MudTh Style="width:170px">Status</MudTh>
            <MudTh>Scenario chain</MudTh>
            <MudTh Style="width:160px">Goal</MudTh>
            <MudTh Style="width:180px">Life Areas</MudTh>
        </HeaderContent>

        <RowTemplate>

            <!-- ── Col 1: Tasks ── -->
            <MudTd>
                <div class="task-cell">
                    @foreach (var task in context.Tasks)
                    {
                        <div class="task-row">

                            @if (IsTracked)
                            {
                                <button class="icon-btn icon-btn--remove"
                                        title="Remove from tracker"
                                        @onclick="() => RemoveFromTrack(task.Id)">
                                    @((MarkupString)RemoveIconSvg)
                                </button>
                            }
                            else
                            {
                                <button class="icon-btn icon-btn--add"
                                        title="Add to tracker"
                                        @onclick="() => AddToTrack(task.Id)">
                                    @((MarkupString)AddIconSvg)
                                </button>
                            }

                            <span class="status-dot"
                                  title="@task.CurrentStatus.ToString()"
                                  style="color:var(@GetStatusCssVar(task.CurrentStatus))">
                                @((MarkupString)GetStatusSvg(task.CurrentStatus))
                            </span>

                            <a href="/task/@task.Id" class="task-link">
                                @task.Name
                            </a>

                        </div>
                    }
                </div>
            </MudTd>

            <!-- ── Col 2: Status ── -->
            <MudTd Style="width:170px">
                <div class="task-cell">

                    @foreach (var task in context.Tasks)
                    {
                        <details class="status-details">

                            <summary class="status-trigger">

                                <span class="status-dot"
                                      style="color:var(@GetStatusCssVar(task.CurrentStatus))">
                                    @((MarkupString)GetStatusSvg(task.CurrentStatus))
                                </span>

                                <span class="status-label">
                                    @task.CurrentStatus
                                </span>

                                <span class="status-caret">▾</span>

                            </summary>

                            <div class="status-dropdown">

                                @foreach (CurrentStatus s in Enum.GetValues<CurrentStatus>())
                                {
                                    var captured = s;
                                    var capturedTask = task;

                                    <button class="status-option"
                                            @onclick="() => OnStatusChanged(capturedTask, captured)">

                                        <span class="status-dot"
                                              style="color:var(@GetStatusCssVar(captured))">
                                            @((MarkupString)GetStatusSvg(captured))
                                        </span>

                                        <span>@captured</span>

                                    </button>
                                }

                            </div>

                        </details>
                    }

                </div>
            </MudTd>

            <!-- ── Col 3: Scenario chain ── -->
            <MudTd>

                <div class="chain-wrap">

                    @foreach (var node in context.ScenarioChain)
                    {
                        if (node.IsProject)
                        {
                            <a href="/project/@node.Id"
                               class="chain-node chain-node--project">

                                <svg class="chain-icon" viewBox="0 0 24 24">
                                    <path d="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" />
                                </svg>

                                @node.Label

                            </a>
                        }
                        else
                        {
                            <a href="/scenario/@node.Id"
                               class="chain-node chain-node--scenario">

                                @node.Label

                            </a>

                            <span class="chain-sep">›</span>
                        }
                    }

                </div>

            </MudTd>

            <!-- ── Col 4: Goal ── -->
            <MudTd Style="width:160px">

                <a href="/goals/@context.GoalId"
                   class="nav-link nav-link--goal">

                    @context.GoalName

                </a>

            </MudTd>

            <!-- ── Col 5: Life Areas ── -->
            <MudTd Style="width:180px">

                <div class="task-cell">

                    @foreach (var lifeArea in context.LifeAreas)
                    {
                        <a href="/life-areas/@lifeArea.Id"
                           class="nav-link nav-link--lifearea">

                            @lifeArea.Name

                        </a>
                    }

                </div>

            </MudTd>

        </RowTemplate>

        <NoRecordsContent>

            <MudStack AlignItems="AlignItems.Center"
                      Class="py-8"
                      Spacing="2">

                <MudIcon Icon="@Icons.Material.Outlined.SearchOff"
                         Size="Size.Large"
                         Class="mud-text-disabled" />

                <MudText Typo="Typo.body2"
                         Class="mud-text-disabled">

                    No tasks match your filters

                </MudText>

            </MudStack>

        </NoRecordsContent>

    </MudTable>

</MudPaper>

<style>

    .task-cell {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .task-row {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .task-link {
        font-size: .875rem;
        font-weight: 500;
        color: inherit;
        text-decoration: none;
    }

        .task-link:hover {
            text-decoration: underline;
        }

    .nav-link {
        font-size: .875rem;
        text-decoration: none;
    }

    .nav-link--goal {
        color: var(--mud-palette-tertiary);
    }

    .nav-link--lifearea {
        color: var(--mud-palette-secondary);
    }

    .nav-link:hover {
        text-decoration: underline;
        opacity: .8;
    }

    .icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        padding: 0;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        background: transparent;
        transition: background .15s;
        flex-shrink: 0;
    }

    .icon-btn--add:hover {
        background: var(--mud-palette-success-hover);
        color: var(--mud-palette-success);
    }

    .icon-btn--remove:hover {
        background: var(--mud-palette-error-hover);
        color: var(--mud-palette-error);
    }

    .status-details {
        position: relative;
        display: inline-block;
    }

        .status-details[open] .status-trigger {
            background: var(--mud-palette-action-hover);
        }

    .status-trigger {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        padding: 2px 6px;
        border-radius: 4px;
        list-style: none;
        font-size: .875rem;
        transition: background .15s;
        user-select: none;
    }

        .status-trigger:hover {
            background: var(--mud-palette-action-hover);
        }

        .status-trigger::-webkit-details-marker {
            display: none;
        }

    .status-caret {
        font-size: .7rem;
        color: var(--mud-palette-text-disabled);
        margin-left: 2px;
    }

    .status-label {
        white-space: nowrap;
    }

    .status-dropdown {
        position: absolute;
        z-index: 1000;
        left: 0;
        top: 100%;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 6px;
        box-shadow: 0 4px 16px rgba(0,0,0,.12);
        min-width: 160px;
        padding: 4px 0;
        margin-top: 2px;
    }

    .status-option {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        padding: 6px 12px;
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: .875rem;
        color: var(--mud-palette-text-primary);
        text-align: left;
        transition: background .1s;
    }

        .status-option:hover {
            background: var(--mud-palette-action-hover);
        }

    .chain-wrap {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 2px;
    }

    .chain-node {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: .8rem;
        text-decoration: none;
        padding: 2px 6px;
        border-radius: 10px;
        transition: opacity .15s;
        white-space: nowrap;
    }

        .chain-node:hover {
            opacity: .7;
        }

    .chain-node--scenario {
        color: var(--mud-palette-text-secondary);
        background: var(--mud-palette-action-default-hover);
    }

    .chain-node--project {
        color: var(--mud-palette-primary);
        background: var(--mud-palette-primary-hover);
        font-weight: 600;
        border: 1px solid var(--mud-palette-primary);
    }

    .chain-icon {
        width: 12px;
        height: 12px;
        fill: currentColor;
        flex-shrink: 0;
    }

    .chain-sep {
        color: var(--mud-palette-text-disabled);
        font-size: .85rem;
        padding: 0 1px;
    }

    .status-dot {
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
    }

        .status-dot svg {
            width: 16px;
            height: 16px;
            fill: currentColor;
        }

</style>

@code {

    [Parameter, EditorRequired]
    public List<TaskHierarchyLifeAreaDTO> LifeAreas { get; set; } = [];

    [Parameter]
    public EventCallback<(int TaskId, CurrentStatus NewStatus)> OnTaskStatusChanged { get; set; }

    [Parameter]
    public bool IsTracked { get; set; }

    private string _searchText = "";

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            RebuildFiltered();
        }
    }

    private CurrentStatus? _filterStatus;

    private CurrentStatus? FilterStatus
    {
        get => _filterStatus;
        set
        {
            _filterStatus = value;
            RebuildFiltered();
        }
    }

    private string? _filterLifeAreaName;

    private string? FilterLifeAreaName
    {
        get => _filterLifeAreaName;
        set
        {
            _filterLifeAreaName = value;
            RebuildFiltered();
        }
    }

    private List<TaskHierarchyLifeAreaDTO>? _prevLifeAreas;

    private List<FlatTaskRow> _allRows = [];

    private List<FlatTaskRow> _filteredRows = [];

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_prevLifeAreas, LifeAreas))
            return;

        _prevLifeAreas = LifeAreas;

        _allRows = BuildFlatRows();

        RebuildFiltered();
    }

    private record TaskEntry(
        int Id,
        string Name,
        CurrentStatus CurrentStatus)
    {
        public CurrentStatus CurrentStatus { get; set; } = CurrentStatus;
    }

    private record FlatTaskRow(
        List<TaskEntry> Tasks,
        int GoalId,
        string GoalName,
        List<(int Id, string Name)> LifeAreas,
        List<ChainNode> ScenarioChain);

    private record ChainNode(
        int Id,
        string Label,
        bool IsProject);

    private void RebuildFiltered()
    {
        IEnumerable<FlatTaskRow> rows = _allRows;

        if (_filterStatus.HasValue)
        {
            rows = rows.Where(r =>
                r.Tasks.Any(t => t.CurrentStatus == _filterStatus.Value));
        }

        if (!string.IsNullOrWhiteSpace(_filterLifeAreaName))
        {
            rows = rows.Where(r =>
                r.LifeAreas.Any(x => x.Name == _filterLifeAreaName));
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var q = _searchText.Trim();

            rows = rows.Where(r =>

                r.Tasks.Any(t =>
                    t.Name.Contains(q, StringComparison.OrdinalIgnoreCase))

                ||

                r.GoalName.Contains(q, StringComparison.OrdinalIgnoreCase)

                ||

                r.LifeAreas.Any(x =>
                    x.Name.Contains(q, StringComparison.OrdinalIgnoreCase))

                ||

                r.ScenarioChain.Any(n =>
                    n.Label.Contains(q, StringComparison.OrdinalIgnoreCase))
            );
        }

        _filteredRows = rows.ToList();
    }

    private List<FlatTaskRow> BuildFlatRows()
    {
        var groups = new Dictionary<string, (
            List<TaskEntry> Tasks,
            TaskHierarchyGoalDTO Goal,
            List<(int Id, string Name)> LifeAreas,
            List<ChainNode> Chain)>();

        void AddTask(
            TaskItemDTO task,
            TaskHierarchyGoalDTO goal,
            TaskHierarchyLifeAreaDTO lifeArea,
            List<ChainNode> chain)
        {
            var key =
                $"{goal.Id}|{string.Join(",", chain.Select(n => $"{n.IsProject}:{n.Id}"))}";

            if (!groups.TryGetValue(key, out var g))
            {
                g = (
                    new List<TaskEntry>(),
                    goal,
                    new List<(int Id, string Name)>(),
                    chain);

                groups[key] = g;
            }

            if (!g.LifeAreas.Any(x => x.Id == lifeArea.Id))
            {
                g.LifeAreas.Add((lifeArea.Id, lifeArea.Name));
            }

            if (!g.Tasks.Any(x => x.Id == task.Id))
            {
                g.Tasks.Add(
                    new TaskEntry(task.Id, task.Name, task.CurrentStatus));
            }
        }

        foreach (var lifeArea in LifeAreas)
        {
            foreach (var goal in lifeArea.Goals)
            {
                foreach (var project in goal.Projects)
                {
                    foreach (var task in project.Tasks)
                    {
                        AddTask(
                            task,
                            goal,
                            lifeArea,
                            [new ChainNode(project.Id, project.Name, true)]);
                    }
                }

                foreach (var scenario in goal.Scenarios)
                {
                    FlattenScenario(
                        scenario,
                        goal,
                        lifeArea,
                        [],
                        AddTask);
                }
            }
        }

        return groups.Values
            .Select(g => new FlatTaskRow(
                g.Tasks,
                g.Goal.Id,
                g.Goal.Name,
                g.LifeAreas,
                g.Chain))
            .ToList();
    }

    private void FlattenScenario(
        TaskHierarchyScenarioDTO scenario,
        TaskHierarchyGoalDTO goal,
        TaskHierarchyLifeAreaDTO lifeArea,
        List<ChainNode> ancestorChain,
        Action<TaskItemDTO,
            TaskHierarchyGoalDTO,
            TaskHierarchyLifeAreaDTO,
            List<ChainNode>> addTask)
    {
        List<ChainNode> currentChain =
        [
            .. ancestorChain,
            new ChainNode(scenario.Id, scenario.Name, false)
        ];

        foreach (var project in scenario.Projects)
        {
            foreach (var task in project.Tasks)
            {
                addTask(
                    task,
                    goal,
                    lifeArea,
                    [
                        .. currentChain,
                        new ChainNode(project.Id, project.Name, true)
                    ]);
            }
        }

        foreach (var child in scenario.Children)
        {
            FlattenScenario(
                child,
                goal,
                lifeArea,
                currentChain,
                addTask);
        }
    }

    private async Task OnStatusChanged(
        TaskEntry task,
        CurrentStatus newStatus)
    {
        task.CurrentStatus = newStatus;

        await OnTaskStatusChanged.InvokeAsync(
            (task.Id, newStatus));
    }

    private static string RowStyle(FlatTaskRow row, int _) =>
        row.Tasks.All(t =>
            t.CurrentStatus is CurrentStatus.Completed
            or CurrentStatus.Cancelled)
                ? "opacity:.55;"
                : "";

    private async Task AddToTrack(int taskId)
    {
        await TaskApi.AddToTrackerAsync(
            taskId,
            DateTime.Today,
            DateTime.Today.AddDays(1));
    }

    private async Task RemoveFromTrack(int taskId)
    {
        await TaskApi.RemoveFromTrackerAsync(taskId);
    }

    private static string GetStatusSvg(CurrentStatus s) => s switch
    {
        CurrentStatus.NotStarted => "<svg viewBox='0 0 24 24'><path d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z'/></svg>",
        CurrentStatus.InProgress => "<svg viewBox='0 0 24 24'><path d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z'/></svg>",
        CurrentStatus.OnHold => "<svg viewBox='0 0 24 24'><path d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z'/></svg>",
        CurrentStatus.Completed => "<svg viewBox='0 0 24 24'><path d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.59L5.41 12l1.42-1.42L10 13.17l7.17-7.17 1.42 1.42L10 16.59z'/></svg>",
        CurrentStatus.Cancelled => "<svg viewBox='0 0 24 24'><path d='M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z'/></svg>",
        _ => "<svg viewBox='0 0 24 24'><path d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z'/></svg>"
    };

    private static string GetStatusCssVar(CurrentStatus s) => s switch
    {
        CurrentStatus.InProgress => "--mud-palette-info",
        CurrentStatus.OnHold => "--mud-palette-warning",
        CurrentStatus.Completed => "--mud-palette-success",
        CurrentStatus.Cancelled => "--mud-palette-error",
        _ => "--mud-palette-text-secondary"
    };

    private static string GetStatusIcon(CurrentStatus s) => s switch
    {
        CurrentStatus.NotStarted => Icons.Material.Outlined.RadioButtonUnchecked,
        CurrentStatus.InProgress => Icons.Material.Filled.PlayCircleOutline,
        CurrentStatus.OnHold => Icons.Material.Filled.PauseCircleOutline,
        CurrentStatus.Completed => Icons.Material.Filled.CheckCircleOutline,
        CurrentStatus.Cancelled => Icons.Material.Filled.Cancel,
        _ => Icons.Material.Filled.Help
    };

    private static Color GetStatusColor(CurrentStatus s) => s switch
    {
        CurrentStatus.NotStarted => Color.Default,
        CurrentStatus.InProgress => Color.Info,
        CurrentStatus.OnHold => Color.Warning,
        CurrentStatus.Completed => Color.Success,
        CurrentStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private const string AddIconSvg =
        "<svg viewBox='0 0 24 24' width='18' height='18' fill='currentColor'><path d='M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z'/></svg>";

    private const string RemoveIconSvg =
        "<svg viewBox='0 0 24 24' width='18' height='18' fill='currentColor'><path d='M19 13H5v-2h14v2z'/></svg>";
}