@page "/life-area"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using GoalTracker.Shared
@using MudBlazor
@inject GoalTracker.Client.Feautures.LifeAreas.LifeAreaApiClient LifeAreaApi
@inject NavigationManager Navigation

<h3>LifeArea</h3>
@if(_hasOwnLifeAreas)
{
    <MudGrid>
    @foreach (var lifeArea in _lifeAreas)
    {
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Style="height: 100%;">
                <MudCardContent>
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                            <MudLink OnClick="() => NavigationToLifeArea(lifeArea.Id)"
                            Typo="Typo.h6" Underline="Underline.Hover" Style="cursor: pointer;">
                            @lifeArea.Name
                        </MudLink>
                        @if (lifeArea.IsDefault)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Default</MudChip>
                        }
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-bottom: 12px;">
                        @lifeArea.Description
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Progress</MudText>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2px;">
                        <MudText Typo="Typo.subtitle2">
                            <span style="color: var(--mud-palette-success);">@lifeArea.AchievePoints</span>
                            <span style="color: var(--mud-palette-text-secondary);"> / @lifeArea.GoalPoints</span>
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @GetProgress(lifeArea).ToString("0")%
                        </MudText>
                    </div>
                    <MudProgressLinear Value="@GetProgress(lifeArea)"
                        Color="Color.Success" Rounded="true" Size="Size.Small"
                        Style="margin-top: 4px;" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>
 
}
else
{
<MudDropContainer T="LifeAreaDTO" Items="_lifeAreas" ItemsSelector="@((item, dropzone) =>string.Compare( item.IsDefault.ToString(), dropzone,true)==0)" ItemDropped="AddedToPersonalArea" Class="d-flex flex-wrap flex-grow-1">
    <ChildContent>
        <MudDropZone T="LifeAreaDTO" Identifier="true" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1">
            <MudText Typo="Typo.h6" Class="mb-4">Recomended life area</MudText>
         </MudDropZone>
        <MudDropZone T="LifeAreaDTO" Identifier=false" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1">
            <MudText Typo="Typo.h6" Class="mb-4">Your life area</MudText>
        </MudDropZone>
    </ChildContent>
    <ItemRenderer>
        <MudPaper Elevation="25" Class="pa-4 my-4">@context.Name</MudPaper>
    </ItemRenderer>
</MudDropContainer>
}


<MudBlazor.MudButton OnClick="ReloadData">Reload Data   </MudBlazor.MudButton>
<MudBlazor.MudButton OnClick="SaveData">Save   </MudBlazor.MudButton>


@code {
    private List<LifeAreaDTO> _lifeAreas = [];
    private bool _hasOwnLifeAreas = false;

    protected override async Task OnInitializedAsync()
    {
        _lifeAreas = await LifeAreaApi.GetLifeAreasAsync();
        _hasOwnLifeAreas = _lifeAreas.Any(x => !x.IsDefault);
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        await base.OnAfterRenderAsync(firstRender); 
    }

    protected async Task ReloadData()
    {
        _lifeAreas = await LifeAreaApi.GetLifeAreasAsync();
        StateHasChanged();
    }

    protected async Task AddedToPersonalArea(MudItemDropInfo<LifeAreaDTO> lifeArea)
    {
        lifeArea.Item.IsDefault = !lifeArea.Item.IsDefault;
    }
    private async Task SaveData(MouseEventArgs args)
    {
        _lifeAreas = await LifeAreaApi.SaveToPersonalArea(_lifeAreas);
        _hasOwnLifeAreas = _lifeAreas.Any(x => !x.IsDefault);
        StateHasChanged();
    }
    private double GetProgress(LifeAreaDTO lifeArea)
    {
        if (lifeArea.GoalPoints == 0) return 0;
        return (double)lifeArea.AchievePoints / lifeArea.GoalPoints * 100;
    }
    private void NavigationToLifeArea(int lifeAreaId)
    {
        Navigation.NavigateTo($"/lifearea/{lifeAreaId}");
    }
}
