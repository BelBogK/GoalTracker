@page "/Project/{id:int}"
@using GoalTracker.Client.Pages.Components
@using GoalTracker.Client.Feautures.Projects
@using GoalTracker.Client.Feautures.Goals
@using GoalTracker.Shared
@using GoalTracker.Shared.Enums
@using MudBlazor
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ProjectsAPIClient ProjectApi
@inject GoalsApiClient GoalsApi

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_project is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                <MudText Typo="Typo.h5">@_project.Name</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@_project.GoalType</MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Error">@_project.Priority</MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Success">@_project.CurrentStatus</MudChip>
            </div>
            <div style="display: flex; gap: 24px; margin-bottom: 16px;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Start: @_project.StartTime.ToString("dd.MM.yyyy")
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    End: @_project.EndTime.ToString("dd.MM.yyyy")
                </MudText>
                @if (_project.CompletedTime.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Success">
                        Completed: @_project.CompletedTime.Value.ToString("dd.MM.yyyy")
                    </MudText>
                }
            </div>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="margin-bottom: 4px;">Description</MudText>
            @if (_editingDescription)
            {
                <MudTextField @bind-Value="_project.Description"
                    Lines="8" Variant="Variant.Outlined" FullWidth="true" />
                <div style="display: flex; gap: 8px; margin-top: 8px;">
                    <MudButton Size="Size.Small" Color="Color.Success" OnClick="SaveDescription">Save</MudButton>
                    <MudButton Size="Size.Small" OnClick="() => _editingDescription = false">Cancel</MudButton>
                </div>
            }
            else
            {
                <div style="min-height: 80px; padding: 12px; border: 0.5px solid var(--mud-palette-divider); border-radius: 8px; cursor: pointer;"
                    @onclick="() => _editingDescription = true">
                    @if (string.IsNullOrEmpty(_project.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Click to add description...</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_project.Description</MudText>
                    }
                </div>
            }
        </MudItem>

        @if (!string.IsNullOrEmpty(_project.Result))
        {
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Result</MudText>
                <MudText Typo="Typo.body2">@_project.Result</MudText>
            </MudItem>
        }

        <MudItem xs="12">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                <MudText Typo="Typo.subtitle1">Goals</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="OpenAddGoalDialog">
                    + Add goal
                </MudButton>
            </div>
            @if (_project.Goals?.Any() == true)
            {
                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    @foreach (var goal in _project.Goals)
                    {
                        var g = goal;
                        <div style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 12px; border-radius: 99px; background-color: var(--mud-palette-primary); color: var(--mud-palette-primary-text); font-size: 13px; cursor: default;">
                            <span>@g.Name</span>
                            <span style="cursor: pointer; color: var(--mud-palette-primary-text); margin-left: 4px; opacity: 0.7;"
                                  @onclick="() => RemoveGoal(g.Id)">✕</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">No goals linked.</MudText>
            } 
        </MudItem>

        <MudItem xs="12">
            <MudText Typo="Typo.subtitle1" Style="margin-bottom: 8px;">Tasks</MudText>
            <TaskTable ProjectId="@id" />
        </MudItem>
    </MudGrid>
}

@* Dialog для выбора Goal *@
<MudDialog @bind-Visible="_addGoalDialogVisible">
    <TitleContent>Add goal to project</TitleContent>
    <DialogContent>
        @if (_allGoals is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudList T="GoalDTO" SelectionMode="SelectionMode.SingleSelection"
                @bind-SelectedValue="_selectedGoal">
             @foreach (var goal in _allGoals)
{
    <MudListItem T="GoalDTO" Value="@goal" @key="goal.Id">
        <div style="display: flex; align-items: center; gap: 8px;">
            <MudChip T="string" Size="Size.Small" Color="Color.Info">@goal.GoalType</MudChip>
            <MudText>@goal.Name</MudText>
        </div>
    </MudListItem>
}
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _addGoalDialogVisible = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="ConfirmAddGoal"
            Disabled="@(_selectedGoal is null)">Add</MudButton>
    </DialogActions>
</MudDialog>

 
@code {
    [Parameter] public int id { get; set; }

    private ProjectDTO? _project;
    private bool _editingDescription = false;
    private bool _addGoalDialogVisible = false;
    private List<GoalDTO>? _allGoals;
    private GoalDTO? _selectedGoal;

    protected override async Task OnParametersSetAsync()
    {
        _project = await ProjectApi.GetProjectByIdAsync(id); 
    }

    private async Task SaveDescription()
    {
        _editingDescription = false;
        await ProjectApi.UpdateProjectAsync(_project!);
    }

    private async Task OpenAddGoalDialog()
    {
        _allGoals = await GoalsApi.GetGoalsAsync();
        _selectedGoal = null;
        _addGoalDialogVisible = true;
    }

    private async Task ConfirmAddGoal()
    {
        if (_selectedGoal is null || _project is null) return;

        await ProjectApi.AddGoalToProjectAsync(_project.Id, _selectedGoal.Id);

        _project.Goals ??= new List<GoalDTO>();
        _project.Goals.Add(_selectedGoal);

        _addGoalDialogVisible = false;
        _selectedGoal = null;
    }

    private async Task RemoveGoal(int goalId)
    {
        if (_project is null) return;
        await ProjectApi.RemoveGoalFromProjectAsync(_project.Id, goalId);
        _project.Goals?.RemoveAll(g => g.Id == goalId);
    }
}
 
